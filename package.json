{
  "name": "theatre-reader",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"pnpm --filter @theatre/server dev\" \"pnpm --filter @theatre/web dev\"",
    "build": "pnpm --filter @theatre/web build",
    "start": "pnpm --filter @theatre/server start",
    "test": "vitest run",
    "typecheck": "pnpm -r --if-present typecheck",
    "setup:browser": "pnpm exec playwright install chromium"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "happy-dom": "^15.11.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
